{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "noEmit": true,
        "jsx": "react-jsx",
        "paths": {
            "@t-suite/shared": ["./packages/shared/src/index.ts"],
            "@t-suite/t-sdk": ["./packages/t-sdk/src/index.ts"]
        }
    },
    "include": [
        "packages/shared/src/**/*.ts",
        "packages/t-sdk/src/**/*.ts",
        "packages/t-sdk-react/src/**/*.ts",
        "packages/t-sdk-react/src/**/*.tsx",
        "packages/t-sdk-vue/src/**/*.ts",
        "packages/t-sdk-astro/src/**/*.ts",
        "packages/t-sdk-cli/src/**/*.ts"
    ]
}
